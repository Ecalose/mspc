{  
    "version": "2.0.9.2",  
    "description": "使用 Flutter 开发的 BiliBili 第三方客户端 | A third-party BiliBili client developed using Flutter",  
    "homepage": "https://github.com/bggRGjQaUbCoE/PiliPlus",  
    "license": {  
        "identifier": "GPL-3.0-only"  
    },  
    "architecture": {  
        "64bit": {  
            "url": "https://github.com/bggRGjQaUbCoE/PiliPlus/releases/download/2.0.9.2/PiliPlus_windows_2.0.9+5051_x64_portable.zip",  
            "hash": "4521782f7a7c4879a7420244f7965a470b96b8aca7628b9c1ff91059ddb26f59"  
        }  
    },  
    "extract_dir": "PiliPlus-Win",  
    "extract_to": "app",  
    "shortcuts": [  
        [  
            "app\\piliplus.exe",  
            "PiliPlus"  
        ]  
    ],  
    "pre_install": [  
        "$target = \"$persist_dir\\appdata\"",  
        "if (!(Test-Path $target)) { New-Item -ItemType Directory -Path $target -Force | Out-Null }",  
        "$link = \"$env:AppData\\com.example\\piliplus\"",  
        "if (Test-Path $link) { if ((Get-Item $link).LinkType -ne 'Junction') { Move-Item $link $target -Force } }",  
        "else { New-Item -ItemType Directory -Path (Split-Path $link) -Force | Out-Null }",  
        "if (!(Test-Path $link)) { cmd /c mklink /J \"$link\" \"$target\" | Out-Null }"  
    ],  
    "pre_uninstall": [  
        "Get-Process piliplus -ErrorAction SilentlyContinue | Stop-Process -Force",  
        "$link = \"$env:AppData\\com.example\\piliplus\"",  
        "if ((Get-Item $link -ErrorAction SilentlyContinue).LinkType -eq 'Junction') { Remove-Item $link -Force }"  
    ],  
    "checkver": {  
        "url": "https://api.github.com/repos/bggRGjQaUbCoE/PiliPlus/releases/latest",  
        "regex": "/download/([^/]+)/PiliPlus_windows_(?<main>[\\d.]+)%2B(?<build>\\d+)_x64_portable.zip"  
    },  
    "autoupdate": {  
        "architecture": {  
            "64bit": {  
                "url": "https://github.com/bggRGjQaUbCoE/PiliPlus/releases/download/$version/PiliPlus_windows_$matchMain+$matchBuild_x64_portable.zip"  
            }  
        }  
    }  
}
